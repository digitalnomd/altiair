# Copy to .env locally or export these values in the shell.
# Do not commit real Foundry URLs, package registry URLs, tokens, client secrets, or private ontology RIDs.

# Node API bind settings for the Pi/Jetson mesh prototype.
# Use the node's WireGuard overlay IP for live demos, for example 10.77.0.10 on altiair-hub.
ALTIAIR_NODE_ID=altiair-hub
ALTIAIR_API_HOST=127.0.0.1
ALTIAIR_API_PORT=8080
ALTIAIR_MISSION_ID=mission-live-edge

# Optional target for piping live adapter JSON through npm run sensor:merge.
ALTIAIR_SENSOR_POST_URL=http://127.0.0.1:8080/sensor-events

# Set locally for protected routes. Do not commit a real token.
ALTIAIR_API_TOKEN=<local-demo-token>

# mock | osdk
FOUNDRY_MODE=mock

# bundle_actions writes the full local CASK contract when matching ontology actions exist.
# cask_gps_position writes only the Atlas-visible [Example] CASK GPS Position action.
FOUNDRY_UPLOAD_PROFILE=bundle_actions

# Required when FOUNDRY_MODE=osdk.
FOUNDRY_API_URL=https://<your-foundry-stack>.palantirfoundry.com
FOUNDRY_ONTOLOGY_RID=ri.ontology.main.ontology.<your-ontology-rid>
FOUNDRY_CLIENT_ID=<developer-console-backend-service-client-id>
FOUNDRY_CLIENT_SECRET=<developer-console-backend-service-client-secret>
FOUNDRY_OSDK_PACKAGE=@cask-edge-service/sdk

# Override these if the generated OSDK action exports differ.
FOUNDRY_ACTION_CREATE_SENSOR_OBSERVATION=createCaskSensorObservation
FOUNDRY_ACTION_CREATE_LOCATION_FIX=createCaskLocationFix
FOUNDRY_ACTION_CREATE_COUNTER_UAS_CUE=createCaskCounterUasCue
FOUNDRY_ACTION_CREATE_INSIGHT_DRAFT=createCaskInsightDraft
FOUNDRY_ACTION_UPSERT_NODE_HEALTH=upsertCaskNodeHealth
FOUNDRY_ACTION_CREATE_CASK_GPS_POSITION=createExampleCaskGpsPosition

# Used only by FOUNDRY_UPLOAD_PROFILE=cask_gps_position when a local LocationFix has no coordinates.
# Keep demo coordinates generic; do not commit real operational positions.
CASK_GPS_DEFAULT_LATITUDE=0
CASK_GPS_DEFAULT_LONGITUDE=0
CASK_GPS_DEFAULT_ALTITUDE_M=0
CASK_GPS_DEFAULT_SPEED_KNOTS=0
CASK_GPS_DEFAULT_COURSE_DEG=0
CASK_GPS_DEFAULT_FIX_QUALITY=1
CASK_GPS_DEFAULT_NUM_SATELLITES=0

# json means each action receives { externalId, payloadJson, sourceNodeId, observedAt, policyState }.
# raw means each action receives the full typed object directly.
FOUNDRY_ACTION_PAYLOAD_STYLE=json

# mock | ollama
LOCAL_LLM_MODE=mock
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
LOCAL_LLM_MODEL=gemma3:1b
