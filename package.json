{
  "name": "altiair-cask-edge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local CASK edge integration scaffold for Foundry OSDK, Pi sensor bundles, and local LLM insight drafts.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "fusion:smoke": "tsx src/scripts/fusion-smoke.ts",
    "mesh:plan": "tsx src/scripts/mesh-plan.ts",
    "mesh:smoke": "tsx src/scripts/mesh-smoke.ts",
    "node:api": "tsx src/scripts/node-api.ts",
    "replication:smoke": "tsx src/scripts/replication-smoke.ts",
    "tag:smoke": "tsx src/scripts/tag-smoke.ts",
    "smoke:mock": "tsx src/scripts/smoke.ts",
    "smoke:foundry": "FOUNDRY_MODE=osdk tsx src/scripts/smoke.ts --foundry"
  },
  "dependencies": {
    "@osdk/client": "^2.13.0",
    "@osdk/oauth": "^1.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
