# Copy to /etc/altiair/altiair-node.env on each Pi.
# Do not put real Foundry secrets in Git.

ALTIAIR_NODE_ID=altiair-hub
ALTIAIR_API_HOST=0.0.0.0
ALTIAIR_API_PORT=8080
ALTIAIR_MISSION_ID=mission-live-edge
ALTIAIR_OPERATOR_AUTHORIZED=false

# Optional bearer token for protected routes.
# ALTIAIR_API_TOKEN=<local-token>

# Target demo mode is node-local Ollama. Use mock only for test/degraded fallback.
LOCAL_LLM_MODE=ollama
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
LOCAL_LLM_MODEL=gemma4:e2b

# Keep Foundry writes on the hub/gateway unless this node has local credentials.
FOUNDRY_MODE=mock
FOUNDRY_UPLOAD_PROFILE=cask_gps_position
FOUNDRY_ACTION_CREATE_CASK_GPS_POSITION=createExampleCaskGpsPosition
FOUNDRY_ACTION_PAYLOAD_STYLE=raw
